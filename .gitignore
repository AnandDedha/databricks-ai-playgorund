# ============================================================
# ShopMate AI — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
env/
.venv/
.env

# --- Jupyter / Databricks ---
.ipynb_checkpoints/
*.ipynb_meta
.databricks/
.databricks-connect

# --- Secrets (NEVER commit these) ---
*.env
.env.local
.env.*.local
secrets.yaml
secrets.json
credentials.json
*.pem
*.key
config.local.*

# --- Databricks PAT / workspace tokens ---
.databrickscfg
databricks_token
.dbx/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS junk ---
.Trash-*
desktop.ini

# --- Build / output artifacts that shouldn't be tracked ---
*.log
*.tmp
*.bak
output/
tmp/

# --- Generated assets (uncomment if you generate large media locally) ---
# assets/screenshots/*.png
# assets/recordings/

# --- Allow specific files even if patterns above match ---
!.gitkeep
!.env.example
