# ============================================================
# ShopMate AI — Environment variables template
# ============================================================
# Copy this file to .env and fill in your own values.
# NEVER commit .env to git — it's in .gitignore for a reason.

# --- Databricks workspace ---
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=dapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Unity Catalog targets ---
UC_CATALOG=techbazaar
UC_SCHEMA=shopmate
UC_VOLUME=raw_data

# --- Vector Search ---
VECTOR_SEARCH_ENDPOINT=shopmate_vs_endpoint
EMBEDDING_MODEL=databricks-gte-large-en

# --- Slack MCP (optional — only if using Slack escalation tool) ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0XXXXXXXXX
SLACK_TEAM_ID=T0XXXXXXXXX

# --- FastMCP fallback server (optional) ---
MCP_SERVER_PORT=8080
NGROK_AUTH_TOKEN=

# --- LLM model to use in Playground (informational only) ---
PLAYGROUND_MODEL=databricks-claude-opus-4

# --- Logging ---
LOG_LEVEL=INFO
